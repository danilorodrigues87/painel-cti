# Copie para .env e preencha (nunca commitar o .env)

URL=http://localhost/pjt/painel-cti
SITE=Painel CTI

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=painel_cti

SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_CHARSET=UTF-8
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_ENCRYPTION=tls

APP_KEY=
SYSTEM_TOKEN=
JWT_KEY=
MAINTENANCE=false
TIMEZONE=America/Sao_Paulo
CACHE_TIME=0
CACHE_DIR=
PAGINATION_LIMIT=10
MY_TOKEN=

# Evolution API (WhatsApp) — global do servidor
EVOLUTION_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# Painel Master — e-mails com acesso a /master (separados por vírgula)
MASTER_EMAILS=ctieducacional@gmail.com

# Mercado Pago — conta CTI (cobrança SaaS das escolas no Master)
# Diferente do token por escola (carnê de alunos).
MP_CTI_ACCESS_TOKEN=
MP_CTI_WEBHOOK_SECRET=
MP_CTI_WEBHOOK_TOKEN=
# E-mail fallback do pagador PIX se a escola não tiver e-mail válido
MP_CTI_PAYER_EMAIL=
